# Credential and profile files
*.env
.env.*
*-profiles.json
*_profiles.json

# Private keys and certificates
*.pem
*.p8
*.key
*.pfx
*.p12

# Tokens and secrets
*token*.txt
*secret*.txt
*credentials*.json
*credentials*.yaml

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
*.egg-info/
dist/
build/

# macOS
.DS_Store

# Editor
*.swp
*.swo
.idea/
.vscode/

# Temp / test output files
/tmp/
*.tmp

# Tableau Hyper engine logs (created by tableauhyperapi in cwd)
hyperd.log

# Local test data
.data/

# AI tool local settings — ignore personal config, track shared project config
# (.claude/agents/, .claude/rules/, .claude/settings.json are committed; settings.local.json is not)
.cursor/
.claude/settings.local.json
.gemini/

# Deployment state (local only — tracks last Snowflake stage sync)
.snowflake-deploy-sha

# Per-machine smoke test configuration (model names, connection details, etc.)
tools/smoke-tests/smoke-config.local.json

# Databricks bundle — shared/ is copied from agents/shared/ at deploy time
agents/databricks/shared/

# Databricks vendored Genie notebook — generated by build_mv_lib.py at deploy
# time from tools/ts-cli's pure modules; never committed
agents/databricks/notebooks/databricks_mv_lib.py

# Implementation plans — local working artifacts, not part of the published repo
# (design specs under docs/superpowers/specs/ ARE tracked; plans are not)
docs/superpowers/plans/